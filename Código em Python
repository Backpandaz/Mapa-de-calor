# IMPORTANDO BIBLIOTECAS
import matplotlib.pyplot as plt
import numpy as np
from matplotlib.colors import LogNorm
import matplotlib.colors as colors


#FUNDO ESCURO
plt.style.use('dark_background')

# EQUAÇÃO DA FORMA GEOMETRICA
def rbf(x, y):
    return (x / 2)**2 + (y / 1)**2


# RESOLUÇÃO
N = 200


# VALOR DE INCREMENTO PARA A FUNÇÃO MAIS DENSA
gain = 2


# DISTÂNCIA DOS EIXOS X E Y
X, Y = np.mgrid[-3:3:complex(0, N), -1:1:complex(0, N)]


# EQUAÇÕES PARA MOSTRAR A  DIFERENÇA ENTRE AS DUAS REGIOES
Z1 = rbf(X + 0, Y + 0)
Z2 = rbf(X - 0, Y - 0)
Z = Z1 * gain - Z2


# DEFININDO O MAPA DE CALOR E SEU ESQUEMA DE CORES
shadeopts = {'cmap': 'inferno', 'shading': 'gouraud'}
colormap = 'PRGn'
lnrwidth = 0.1
fig, ax = plt.subplots(1, 1, sharex=True, sharey=True)


# DEFININDO A FUNÇÃO LOGARÍTMICA
pcm = ax.pcolormesh(X, Y, Z,
                       norm=colors.SymLogNorm(linthresh=lnrwidth, linscale=0.1,
                                              vmin=-gain, vmax=gain, base=10),
                       **shadeopts)
